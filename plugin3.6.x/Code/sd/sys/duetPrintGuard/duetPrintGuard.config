[DUET]
# IP address of duet printer
# Mandatory
DUETIP = 192.168.30.41

# Password for duet
# Optional
#PASSWORD = 

# PORT cannot conflict with other apps / plugins
# Mandatory
PORT = 8002

# DEBUG is set to False for normal production use
# Valid entries [True,False]
# Optional - Default is False
DEBUG = True

# Type of notification to be sent on print failure
# Valid Entries [MACRO, X, Y,]
# Optional
#NOTIFYTYPE = MACRO

# Duet Macro to be called if NOTIFYTYPE = MACRO
# The bit that comes after M98
# Optional
NOTIFYMACRO = 

# Url of notofocation service if NOTIFYTYPE = X or Y
# NOTIFYURL =

# User for notification service if NOTIFYTYPE = X or Y
#NOTIFYUSER = 

# Password  for notofocation service if NOTIFYTYPE = X or Y
#NOTIFYPWD = 


